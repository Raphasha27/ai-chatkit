# ==============================================================================
# Kirov Dynamics Standard .gitignore — AI ChatKit
# ==============================================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/
.nuxt/

# Environment variables
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test

# IDE files
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# Runtime
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
*.lcov
.nyc_output

# Cache
.cache/
.parcel-cache/
.vite/

# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/

# ==============================================================================
# .NET / C#
# ==============================================================================
bin/
obj/
*.user
*.userosscache
*.sln.docstates

# ==============================================================================
# Java / Spring Boot
# ==============================================================================
target/
*.class
*.jar
*.war
*.ear

# ==============================================================================
# Project-Specific
# ==============================================================================
# ChromaDB vector store
resource/chroma_db/

# SQLite database files
*.db
*.sqlite
*.sqlite3

# UV lock artefacts (keep uv.lock but ignore local uv cache)
.uv/

# Docusaurus / docs build
.docusaurus/

# Vercel
.vercel
