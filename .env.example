# ==============================================================================
# AI ChatKit — Environment Variables
# Kirov Dynamics Technology | Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_NAME=ai-chatkit
APP_ENV=development
DEBUG=false
DEV=true
PORT=8000
HOST=0.0.0.0

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here

# ------------------------------------------------------------------------------
# LLM Provider
# Set LLM_PROVIDER to one of: openai | gemini | anthropic | deepseek | dashscope
# ------------------------------------------------------------------------------
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_MODEL=gpt-4o-mini

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# DeepSeek
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEFAULT_MODEL=deepseek-chat

# Alibaba DashScope (Qwen)
# DASHSCOPE_API_KEY=your_dashscope_api_key_here
# DEFAULT_MODEL=qwen-plus

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
# SQLite (default for local development)
DATABASE_URL=sqlite+aiosqlite:///resource/database.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_chatkit

# MySQL
# DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/ai_chatkit

# Redis (optional — session / rate-limit cache)
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# Embeddings & Vector Store
# ------------------------------------------------------------------------------
# Use bge-m3 for multilingual embeddings; requires local Ollama deployment
EMBEDDING_MODEL=bge-m3

# Relative storage path for ChromaDB
CHROMA_PATH=resource/chroma_db

# ------------------------------------------------------------------------------
# Ollama (local LLM deployment)
# ------------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ------------------------------------------------------------------------------
# Frontend
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
